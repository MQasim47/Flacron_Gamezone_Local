# Server
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000
JWT_SECRET=change_me_super_secret

# Database
DATABASE_URL=postgresql://username:password@your-host-pooler.region.provider.tech/dbname?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://username:password@your-host.region.provider.tech/dbname?sslmode=require

# Redis
UPSTASH_REDIS_REST_URL=https://your-database-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token-here

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Football API (optional)
API_FOOTBALL_KEY=
API_FOOTBALL_BASEURL=https://v3.football.api-sports.io

API_SPORT_MONKS_KEY=
API_SPORT_MONKS_BASEURL=https://api.sportmonks.com/v3/football

# AI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Youtube API Key
YOUTUBE_API_KEY=

# Brevo
BREVO_API_KEY=your-brevo-api-key-here
CONTACT_FORM_TO_EMAIL=support@flacrongamezone.com
CONTACT_FORM_FROM_EMAIL=noreply@flacrongamezone.com
CONTACT_FORM_FROM_NAME=Flacron Gamezone

# SportSRC (Primary provider)
SPORT_SRC_KEY=your-sportsrc-enterprise-key
SPORT_SRC_BASEURL=https://api.sportsrc.org/v2

# Entity Sport (Secondary data provider)
ENTITY_SPORT_KEY=your-entity-sport-key
ENTITY_SPORT_BASEURL=https://restapi.entitysport.com/v2

# Provider config
FOOTBALL_DATA_PROVIDER=sportsrc   # "sportsrc" | "api-football"